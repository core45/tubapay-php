{
    "name": "core45/tubapay-php",
    "description": "Framework-agnostic PHP SDK for TubaPay payment gateway (BNPL - Buy Now, Pay Later)",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tubapay",
        "payment",
        "bnpl",
        "installments",
        "php",
        "sdk"
    ],
    "authors": [
        {
            "name": "Core45",
            "email": "contact@core45.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Core45\\TubaPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Core45\\TubaPay\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=8"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev"
}
